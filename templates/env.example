# OpenClaw Bootstrap 环境变量示例
# 复制此文件为 .env 并根据需要修改
# 注意：.env 文件已被 .gitignore 排除，不会被提交到版本库

# ========================================
# 基础配置
# ========================================

# OpenClaw 工作目录（留空使用默认值）
# macOS 默认: ~/openclaw
# Windows 默认: %USERPROFILE%\openclaw
OPENCLAW_WORK_DIR=

# OpenClaw 配置目录（留空使用默认值）
# macOS 默认: ~/.config/openclaw
# Windows 默认: %APPDATA%\openclaw
OPENCLAW_CONFIG_DIR=

# ========================================
# 安装选项
# ========================================

# 是否启用非交互模式 (true/false)
OPENCLAW_NON_INTERACTIVE=false

# 是否在安装后立即执行 onboarding
OPENCLAW_RUN_ONBOARDING=true

# 是否安装 daemon 服务
OPENCLAW_INSTALL_DAEMON=false

# ========================================
# Provider 配置
# ========================================

# TODO: confirm provider config keys
# 以下为示例，实际 key 名以官方文档为准

# OPENCLAW_PROVIDER=
# OPENCLAW_API_KEY=
# OPENCLAW_API_ENDPOINT=

# ========================================
# 网络配置
# ========================================

# HTTP 代理（如果在公司网络中）
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=http://proxy.example.com:8080
# NO_PROXY=localhost,127.0.0.1

# ========================================
# 日志配置
# ========================================

# 日志级别: info, debug, warn, error
OPENCLAW_LOG_LEVEL=info

# 自定义日志目录（留空使用默认值）
OPENCLAW_LOG_DIR=
