# ========================================
# OpenClaw Bootstrap Installer .gitignore
# ========================================

# 敏感配置文件
.env
.env.local
*.secret
*.key
config.local.json
config.providers.json

# API Keys / Tokens
**/api-key*
**/token*
**/client-secret*

# 日志文件
logs/
*.log

# 操作系统文件
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# 编辑器 / IDE
.vscode/
.idea/
*.swp
*.swo
*~
*.bak

# Node.js (如果后续扩展)
node_modules/
package-lock.json
yarn.lock

# 构建产物
dist/
build/
out/

# 备份文件
backups/
*.backup
*.bak

# 临时文件
tmp/
temp/
*.tmp
